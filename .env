# ─────────────────────────────────────────────────────────────────────────────
# Windrose Dedicated Server — Environment Configuration
# Used by docker-compose.yml for local/testing deployments.
# For Unraid, these values live in windrose-server.xml instead.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server Identity ──────────────────────────────────────────────────────────

# Code players paste under Play ₒ Connect to Server to find your server.
# Min 6 chars, alphanumeric (0-9, a-z, A-Z), case-sensitive.
INVITE_CODE=windrose

# Display name shown in the server browser.
SERVER_NAME=Windrose Docker

# Password to join. Leave empty for a public server.
SERVER_PASSWORD=

# ── Gameplay ₀───────────────────────────────────────────────────────────

# Max simultaneous players. 4 recommended for best performance.
MAX_PLAYERS=4

# ── Networking ───────────────────────────────────────────────────────────────

# IP address the listening socket binds to.
# 0.0.0.0 = all interfaces (recommended).
# Windrose uses relay/NAT punch-through —"no port forwarding required.
P2P_PROXY_ADDRESS=0.0.0.0

# ── Startup Behaviour ────────────────────────────────────────────────────────

# Validate and update server files via SteamCMD on every start.
# Set to false to skip (faster restarts; update manually instead).
UPDATE_ON_START=true

# Auto-generate ServerDescription.json and WorldDescription.json if missing.
GENERATE_SETTINGS=true

# ── Permissions ──────────────────────────────────────────────────────────────

# User/Group ID the server process runs as.
# Linux default: 1000/1000. Unraid uses 99/100 (nobody/users).
PUID=1000
PGID=1000
